# Example environment file for backend
# Copy this to .env and update values for your environment

# Database Configuration
# PostgreSQL examples:
# Local: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_db
# Hosted: DATABASE_URL=postgresql://user:password@host/database_name?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Secret key for JWT/security (change in production)
SECRET_KEY=your-secret-key-change-in-production

# Debug mode (False in production)
DEBUG=True

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
